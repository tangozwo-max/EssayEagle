        <dc:title>Cognitive-behavioral high parental involvement treatments for pediatric obsessive-compulsive disorder: A meta-analysis</dc:title>
        <dcterms:abstract>A meta-analysis estimated the efficacy of cognitive-behavior-family treatment for children and adolescents with OCD and examined moderators, using standardized pretest-posttest mean change indices across 27 studies.</dcterms:abstract>
        <dc:date>2017</dc:date>
